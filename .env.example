# HUZA FRESH — environment template
# Copy to `.env` and fill in real values before hosting.

# --- Required ---
# Local Postgres (start the PostgreSQL Windows service if you see "Can't reach database server at localhost:5432"):
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/huza_marketplace?schema=public&connect_timeout=30&pool_timeout=30&connection_limit=15"
#
# Neon (App Platform / production):
# - DATABASE_URL = *pooler* host (…-pooler…) for the running app
# - DIRECT_URL   = *direct* host (no -pooler) for prisma migrate (required on DO builds)
# Do NOT use channel_binding=require.
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=30&pool_timeout=30&connection_limit=10"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=30"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/huza_marketplace?schema=public&connect_timeout=30&pool_timeout=30&connection_limit=15"
# Local: same as DATABASE_URL. Production (Neon): non-pooler direct connection string.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/huza_marketplace?schema=public&connect_timeout=30"
NEXTAUTH_URL="https://www.youthhuza.rw"
NEXTAUTH_SECRET="generate-a-long-random-secret"

# Local development example:
# NEXTAUTH_URL="http://localhost:3000"

# --- Email (password reset + order emails) ---
# Create a Resend account, verify youthhuza.rw, then set:
RESEND_API_KEY=""
EMAIL_FROM="HUZA FRESH <info@youthhuza.rw>"
SUPPORT_EMAIL="info@youthhuza.rw"

# Optional display phone until WhatsApp is ready:
# SUPPORT_PHONE_DISPLAY="+250 7XX XXX XXX"

# --- Image uploads (required in production) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- WhatsApp (optional until Business number is ready) ---
# Example: WHATSAPP_URL="https://wa.me/2507XXXXXXXX"
# Or set Admin → Settings → whatsapp_url
WHATSAPP_URL=""

# --- Background jobs (required for cron) ---
# Call GET/POST /api/jobs/process with: Authorization: Bearer <JOBS_SECRET>
# Never put the secret in the query string.
JOBS_SECRET="generate-a-long-random-jobs-secret"

# Demo Mobile Money (local/dev only). Ignored unless explicitly true in production.
# ALLOW_DEMO_PAYMENTS="true"

# Optional MTN callback shared secret (header x-callback-secret)
# MTN_MOMO_CALLBACK_SECRET=

# --- Optional Redis cache ---
# REDIS_URL="redis://..."

# --- Payments (add when you receive provider keys) ---
# Without these, checkout uses DEMO mode only when ALLOW_DEMO_PAYMENTS=true or NODE_ENV!=production.
# MTN_MOMO_SUBSCRIPTION_KEY=
# MTN_MOMO_API_USER=
# MTN_MOMO_API_KEY=
# MTN_MOMO_TARGET_ENVIRONMENT=sandbox
# MTN_MOMO_CALLBACK_HOST=https://www.youthhuza.rw
# AIRTEL_CLIENT_ID=
# AIRTEL_CLIENT_SECRET=
# AIRTEL_TARGET_ENVIRONMENT=sandbox

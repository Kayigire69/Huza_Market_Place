DATABASE_URL="postgresql://huza:huza_dev_pass@localhost:5432/huza_marketplace?schema=public"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXT_PUBLIC_APP_NAME="HUZA FRESH"
NEXT_PUBLIC_COMPANY_NAME="Youth Huza"

# Youth Huza merchant number — customers pay THIS number (not farm partners)
HUZA_MERCHANT_PHONE="0788000000"
HUZA_MERCHANT_NAME="Youth Huza — HUZA FRESH"

# --- Redis (optional) — cart sync, homepage/bestsellers cache, job fan-out ---
# REDIS_URL="redis://localhost:6379"

# --- Database pooling tip (hosting) ---
# Prefer a pooled DATABASE_URL (PgBouncer / Neon pooler) in production so
# concurrent page loads do not exhaust Postgres connections.

# --- Cloudinary (optional) — CDN image hosting; falls back to public/uploads ---
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# --- Background jobs ---
# Protect POST /api/jobs/process in production:
# JOBS_SECRET="replace-with-a-long-random-secret"
# Cron example: curl -X POST -H "Authorization: Bearer $JOBS_SECRET" https://your.app/api/jobs/process

# --- Prisma Accelerate (later, high traffic) ---
# Replace DATABASE_URL with your Accelerate connection string when ready:
# DATABASE_URL="prisma://...accelerate.prisma-data.net/?api_key=..."

# --- Daily DB backups ---
# npm run db:backup
# Cron: 0 2 * * * cd /path/to/Huza_Market_Place && npm run db:backup

# --- Maps / geocoding (optional) ---
# With a Google key, checkout uses Geocoding + Places Autocomplete.
# Without it, HUZA falls back to OpenStreetMap Nominatim (same UX).
# GOOGLE_MAPS_API_KEY=""
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Mobile Money (optional for live prompts) ---
# Without these keys the app runs in DEMO mode.

# MTN_MOMO_BASE_URL="https://sandbox.momodeveloper.mtn.com"
# MTN_MOMO_SUBSCRIPTION_KEY=""
# MTN_MOMO_API_USER=""
# MTN_MOMO_API_KEY=""
# MTN_MOMO_TARGET_ENV="sandbox"
# MTN_MOMO_CALLBACK_URL="http://localhost:3000/api/payments/callback/mtn"

# AIRTEL_BASE_URL="https://openapi.airtel.africa"
# AIRTEL_CLIENT_ID=""
# AIRTEL_CLIENT_SECRET=""

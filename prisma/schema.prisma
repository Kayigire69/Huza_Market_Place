generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  SUPPLIER
  ADMIN
  DELIVERY
  WAREHOUSE
  PROCUREMENT
  SUPPORT
}

enum SupplierStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  REMOVED
}

enum AvailabilityStatus {
  OPEN
  BUSY
  CLOSED
}

enum ProductAvailability {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  COMING_SOON
  TEMPORARILY_UNAVAILABLE
}

enum OrderStatus {
  PENDING
  PAID
  CONFIRMED
  PREPARING
  PACKED
  READY_FOR_DISPATCH
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
  CASH_ON_DELIVERY
  CARD
}

enum DeliverySlot {
  TODAY
  TOMORROW
  SCHEDULED
}

enum ReviewType {
  PRODUCT
  DELIVERY
  EXPERIENCE
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketType {
  GENERAL
  COMPLAINT
  RETURN
  REFUND
  CALL_REQUEST
}

enum StockMovementType {
  RECEIVE
  SALE
  ADJUST
  DAMAGE
  RETURN
  TRANSFER
  COUNT
}

enum PaymentStatus {
  PENDING
  VERIFIED
  CONFIRMED
  FAILED
  REFUNDED
}

enum DeliveryZone {
  KIGALI
  KAMONYI_RUYENZI
  BUGESERA_NYAMATA
}

enum UnitType {
  KG
  PIECE
  BUNCH
  LITRE
  PACK
  DOZEN
}

enum NotificationChannel {
  SMS
  EMAIL
  IN_APP
  WHATSAPP
}

enum NotificationType {
  ORDER_CONFIRMATION
  PAYMENT_CONFIRMATION
  DELIVERY_UPDATE
  PROMOTIONAL
  NEW_PRODUCT
  LOW_STOCK
  SUPPLIER_STATUS
  ORDER_PACKED
  ORDER_OUT_FOR_DELIVERY
  ORDER_DELIVERED
  PO_RECEIVED
  PAYMENT_PROCESSED
  DELIVERY_SCHEDULE
  NEW_SUPPLIER
  FAILED_PAYMENT
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String    @unique
  passwordHash  String
  fullName      String
  role          Role      @default(CUSTOMER)
  locale        String    @default("en")
  loyaltyPoints Int       @default(0)
  referralCode  String?   @unique
  referredBy    String?
  isActive      Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  favorites     Favorite[]
  orders        Order[]
  reviews       Review[]
  notifications Notification[]
  supplier      Supplier?
  deliveries    Delivery[] @relation("DeliveryPerson")
  supportTickets SupportTicket[]
  reviewReplies Review[] @relation("ReviewReplies")
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String   @default("Home")
  fullAddress String
  district    String?
  sector      String?
  gpsLat      Float?
  gpsLng      Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Supplier {
  id                 String             @id @default(cuid())
  userId             String             @unique
  businessName       String
  description        String?
  location           String
  district           String
  sector             String?
  phone              String
  email              String?
  nationalId         String?
  companyRegNo       String?
  tin                String?
  farmSize           String?
  productionCapacity String?
  productCategories  String?
  paymentMomo        String?
  bankAccount        String?
  bankName           String?
  /// Document / media URLs (paths or external links)
  nationalIdUrl      String?
  businessCertUrl    String?
  tinDocUrl          String?
  foodSafetyUrl      String?
  organicCertUrl     String?
  permitUrl          String?
  farmPhotoUrls      String[]           @default([])
  productPhotoUrls   String[]           @default([])
  documentsUrl       String?

  /// Farmer personal dossier (Module 9)
  profilePhotoUrl    String?
  gender             String?
  province           String?
  cell               String?
  village            String?
  ageRange           String?

  /// Field information (farm-level defaults)
  fieldType          String?
  pastCropsSeason1   String?
  pastCropsSeason2   String?
  pastCropsSeason3   String?
  currentCrop        String?
  chemicalsPerWeek   String?
  chemicalsWhy       String?
  chemicalsDosage    String?
  fertilizerPerWeek  String?
  irrigationMethod   String?
  diseasesIdentified String?
  pestsIdentified    String?

  /// Production (farm-level summary)
  totalQuantityHarvested String?
  qualityGeneral         String?

  /// Sales summary
  priceUnit              String?
  pricePerUnit           Int?
  totalKgsBoughtByHuza   Float?            @default(0)

  /// Payment options preferred by farmer
  paymentOption          String?
  farmGatePrice          Int?
  priceUponDelivery      Int?
  priceAfterSale         Int?
  proofOfPaymentUrl      String?
  farmerComments         String?

  status             SupplierStatus     @default(PENDING)
  availability       AvailabilityStatus @default(CLOSED)
  openHour           Int                @default(6)
  closeHour          Int                @default(21)
  ratingAvg          Float              @default(0)
  ratingCount        Int                @default(0)
  rejectionReason    String?
  adminNotes         String?
  inspectionScheduledAt DateTime?
  approvedAt         DateTime?
  isVerified         Boolean            @default(false)
  verificationBadge  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  products       Product[]
  reviews        Review[]
  orders         OrderItem[]
  offers         SupplierOffer[]
  purchaseOrders PurchaseOrder[]
  goodsReceipts  GoodsReceipt[]
  messages       ProcurementMessage[]
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  nameEn      String
  nameFr      String
  nameRw      String
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  products    Product[]
  offers      SupplierOffer[]
}

model Product {
  id            String   @id @default(cuid())
  supplierId    String
  categoryId    String
  nameEn        String
  nameFr        String
  nameRw        String
  descriptionEn String
  descriptionFr String
  descriptionRw String
  /// Optional nutritional facts shown to customers
  nutritionalInfo String?
  /// Origin district (e.g. Nyabihu) — never supplier name
  originDistrict  String?
  price         Int
  unit          UnitType @default(KG)
  stockQty      Int      @default(0)
  /// Held for pending (unpaid) orders — available = stockQty - reservedQty
  reservedQty   Int      @default(0)
  lowStockAt    Int      @default(5)
  /// Manual override; when null, derived from stock levels
  availability  ProductAvailability?
  deletedAt     DateTime?
  barcode       String?
  isOrganic     Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  isBestSeller  Boolean  @default(false)
  isNewArrival  Boolean  @default(false)
  isActive      Boolean  @default(true)
  /// Huza review of farmer-listed product
  reviewStatus  String   @default("PENDING")
  reviewNote    String?
  reviewedAt    DateTime?

  /// Crop / field details for this listing (used in accept/reject)
  fieldType          String?
  fieldSize          String?
  pastCropsSeason1   String?
  pastCropsSeason2   String?
  pastCropsSeason3   String?
  currentCrop        String?
  chemicalsPerWeek   String?
  chemicalsWhy       String?
  chemicalsDosage    String?
  fertilizerPerWeek  String?
  irrigationMethod   String?
  diseasesIdentified String?
  pestsIdentified    String?
  totalQuantityHarvested String?
  qualityGeneral         String?
  priceUnit              String?
  pricePerUnit           Int?
  totalKgsBoughtByHuza   Float?  @default(0)
  paymentOption          String?
  farmGatePrice          Int?
  priceUponDelivery      Int?
  priceAfterSale         Int?
  proofOfPaymentUrl      String?
  farmerComments         String?

  ratingAvg     Float    @default(0)
  ratingCount   Int      @default(0)
  location      String?
  /// Districts where this product can be delivered / is available
  availableDistricts String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supplier   Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category   Category         @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  orderItems OrderItem[]
  reviews    Review[]
  favorites  Favorite[]
  stockLogs  StockHistory[]
  batches    StockBatch[]
  movements  StockMovement[]
  goodsReceiptItems GoodsReceiptItem[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id                   String        @id @default(cuid())
  orderNumber          String        @unique
  userId               String?
  guestName            String?
  guestPhone           String?
  deliveryAddress      String
  deliveryZone         DeliveryZone
  deliveryFee          Int
  gpsLat               Float?
  gpsLng               Float?
  deliveryInstructions String?
  deliverySlot         DeliverySlot  @default(TODAY)
  scheduledFor         DateTime?
  estimatedDelivery    String?
  promoCode            String?
  discountAmt          Int           @default(0)
  subtotal             Int
  total                Int
  status               OrderStatus   @default(PENDING)
  packedAt             DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user      User?          @relation(fields: [userId], references: [id])
  items     OrderItem[]
  payment   Payment?
  delivery  Delivery?
  statusLog OrderStatusLog[]
  returns   ReturnRequest[]
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  supplierId String
  quantity   Float
  unitPrice  Int
  lineTotal  Int

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          PaymentMethod
  phoneNumber     String
  amount          Int
  status          PaymentStatus @default(PENDING)
  transactionRef  String?
  externalId      String?       @unique
  payeePhone      String?
  payeeName       String?
  providerMessage String?
  verifiedAt      DateTime?
  refundedAt      DateTime?
  refundReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Delivery {
  id               String      @id @default(cuid())
  orderId          String      @unique
  deliveryPersonId String?
  vehicleId        String?
  status           OrderStatus @default(READY_FOR_DISPATCH)
  estimatedMinutes Int?
  routeNotes       String?
  pickedAt         DateTime?
  deliveredAt      DateTime?
  /// Proof of delivery
  podPhotoUrl      String?
  podSignatureUrl  String?
  podNotes         String?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryPerson User?    @relation("DeliveryPerson", fields: [deliveryPersonId], references: [id])
  vehicle        Vehicle? @relation(fields: [vehicleId], references: [id])
}

model Vehicle {
  id           String     @id @default(cuid())
  plateNumber  String     @unique
  label        String
  capacityKg   Int?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  deliveries   Delivery[]
}

model Review {
  id            String     @id @default(cuid())
  userId        String
  productId     String?
  supplierId    String?
  orderId       String?
  type          ReviewType @default(PRODUCT)
  rating        Int
  comment       String?
  photoUrl      String?
  adminReply    String?
  repliedById   String?
  repliedAt     DateTime?
  isReported    Boolean    @default(false)
  isHidden      Boolean    @default(false)
  reportReason  String?
  createdAt     DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier  Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  repliedBy User?     @relation("ReviewReplies", fields: [repliedById], references: [id])
}

model StockHistory {
  id        String   @id @default(cuid())
  productId String
  change    Int
  reason    String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String              @id @default(cuid())
  userId    String?
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  isRead    Boolean             @default(false)
  createdAt DateTime            @default(now())
  user      User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Promotion {
  id            String    @id @default(cuid())
  code          String?   @unique
  titleEn       String
  titleFr       String
  titleRw       String
  descriptionEn String?
  descriptionFr String?
  descriptionRw String?
  discountPct   Int?
  discountAmt   Int?
  buyX          Int?
  getY          Int?
  freeDelivery  Boolean   @default(false)
  isFlashSale   Boolean   @default(false)
  isLoyalty     Boolean   @default(false)
  loyaltyPoints Int?
  isMembership  Boolean   @default(false)
  isReferral    Boolean   @default(false)
  referralBonus Int?
  isActive      Boolean   @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime  @default(now())
}

model BusinessHours {
  id               String   @id @default(cuid())
  dayOfWeek        Int
  openHour         Int      @default(6)
  closeHour        Int      @default(21)
  isClosed         Boolean  @default(false)
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  name        String
  isClosed    Boolean  @default(true)
}

model EmergencyClosure {
  id        String    @id @default(cuid())
  reason    String
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  isActive  Boolean   @default(true)
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  commentEn String
  commentFr String
  commentRw String
  rating    Int      @default(5)
  avatarUrl String?
  isFeatured Boolean @default(true)
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorName  String?
  action     String
  entity     String
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model SupportThread {
  id        String   @id @default(cuid())
  guestName String?
  guestPhone String?
  userId    String?
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  SupportMessage[]
}

model SupportMessage {
  id        String   @id @default(cuid())
  threadId  String
  sender    String   // CUSTOMER | AGENT | SYSTEM
  body      String
  createdAt DateTime @default(now())
  thread    SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String?
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model FaqItem {
  id       String @id @default(cuid())
  questionEn String
  questionFr String
  questionRw String
  answerEn   String
  answerFr   String
  answerRw   String
  sortOrder  Int @default(0)
  isPublished Boolean @default(true)
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  PURCHASED
}

/// Supplier offers produce for Youth Huza to buy (procurement), not for direct customer sales.
model SupplierOffer {
  id              String      @id @default(cuid())
  supplierId      String
  categoryId      String?
  title           String
  description     String?
  unit            UnitType    @default(KG)
  quantityOffered Float
  /// Price Youth Huza would pay the supplier (RWF per unit)
  askPrice        Int
  /// Optional suggested retail price for Huza to sell at
  suggestedRetail Int?
  availableDistricts String[]  @default([])
  status          OfferStatus @default(PENDING)
  adminNote       String?
  purchasedQty    Float?
  /// Huza product created when offer is purchased
  productId       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  supplier       Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category       Category?       @relation(fields: [categoryId], references: [id])
  purchaseOrders PurchaseOrder[]
}

enum PurchaseOrderStatus {
  DRAFT
  ORDERED
  RECEIVED
  INSPECTED
  ACCEPTED
  REJECTED
  PAID
  CANCELLED
}

/// Youth Huza purchase from an approved supplier (procurement).
model PurchaseOrder {
  id               String              @id @default(cuid())
  poNumber         String              @unique
  supplierId       String
  offerId          String?
  status           PurchaseOrderStatus @default(DRAFT)
  productName      String
  category         String?
  unit             UnitType            @default(KG)
  quantity         Float
  negotiatedPrice  Int
  totalAmount      Int
  retailPrice      Int?
  qualityNotes     String?
  rejectionReason  String?
  paymentRef       String?
  paymentMethod    String?
  paidAt           DateTime?
  orderedAt        DateTime?
  receivedAt       DateTime?
  inspectedAt      DateTime?
  notes            String?
  productId        String?
  createdById      String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  supplier Supplier       @relation(fields: [supplierId], references: [id])
  offer    SupplierOffer? @relation(fields: [offerId], references: [id])
  goodsReceipts GoodsReceipt[]

  @@index([supplierId])
  @@index([status])
  @@index([poNumber])
}

model WarehouseLocation {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  zone      String?
  isActive  Boolean  @default(true)
  batches   StockBatch[]
  createdAt DateTime @default(now())
}

model StockBatch {
  id          String    @id @default(cuid())
  productId   String
  batchNumber String
  quantity    Int
  expiryDate  DateTime?
  locationId  String?
  receivedAt  DateTime  @default(now())
  notes       String?
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  location    WarehouseLocation? @relation(fields: [locationId], references: [id])

  @@index([productId])
  @@index([batchNumber])
}

model GoodsReceipt {
  id            String   @id @default(cuid())
  receiptNumber String   @unique
  purchaseOrderId String?
  supplierId    String
  receivedById  String?
  notes         String?
  damageNotes   String?
  receivedAt    DateTime @default(now())
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  items         GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id             String @id @default(cuid())
  goodsReceiptId String
  productId      String?
  productName    String
  quantity       Float
  unit           UnitType @default(KG)
  batchNumber    String?
  expiryDate     DateTime?
  damagedQty     Float    @default(0)
  locationCode   String?
  goodsReceipt   GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  product        Product? @relation(fields: [productId], references: [id])
}

model StockMovement {
  id        String            @id @default(cuid())
  productId String
  type      StockMovementType
  quantity  Int
  reason    String?
  actorId   String?
  createdAt DateTime          @default(now())
  product   Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([type])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model SupportTicket {
  id          String       @id @default(cuid())
  ticketNumber String      @unique
  userId      String?
  guestName   String?
  guestPhone  String?
  type        TicketType   @default(GENERAL)
  status      TicketStatus @default(OPEN)
  subject     String
  body        String
  orderNumber String?
  adminReply  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  user        User?        @relation(fields: [userId], references: [id])
}

model ReturnRequest {
  id          String   @id @default(cuid())
  orderId     String
  reason      String
  status      String   @default("PENDING")
  refundAmt   Int?
  adminNote   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ProcurementMessage {
  id         String   @id @default(cuid())
  supplierId String
  senderRole String
  senderName String
  body       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  category    String
  amount      Int
  notes       String?
  incurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// Durable background jobs (used when Redis is unavailable; also mirrors Redis queue)
model BackgroundJob {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  runAfter    DateTime  @default(now())
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAfter])
  @@index([type])
}

model DeliveryZoneConfig {
  id               String   @id @default(cuid())
  code             String   @unique
  labelEn          String
  labelFr          String   @default("")
  labelRw          String   @default("")
  feeRwf           Int
  etaMinutes       Int      @default(60)
  isActive         Boolean  @default(true)
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WebsiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model OrderSequence {
  year      Int @id
  lastValue Int @default(0)
}

model ErrorLog {
  id        String   @id @default(cuid())
  source    String
  message   String
  stack     String?
  path      String?
  userId    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([source])
}

model HomepageBanner {
  id          String   @id @default(cuid())
  titleEn     String
  titleFr     String   @default("")

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  SUPPLIER
  ADMIN
  DELIVERY
}

enum SupplierStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  REMOVED
}

enum AvailabilityStatus {
  OPEN
  BUSY
  CLOSED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  MTN_MOMO
  AIRTEL_MONEY
}

enum PaymentStatus {
  PENDING
  VERIFIED
  CONFIRMED
  FAILED
  REFUNDED
}

enum DeliveryZone {
  KIGALI
  KAMONYI_RUYENZI
  BUGESERA_NYAMATA
}

enum UnitType {
  KG
  PIECE
  BUNCH
  LITRE
  PACK
  DOZEN
}

enum NotificationChannel {
  SMS
  EMAIL
  IN_APP
  WHATSAPP
}

enum NotificationType {
  ORDER_CONFIRMATION
  PAYMENT_CONFIRMATION
  DELIVERY_UPDATE
  PROMOTIONAL
  NEW_PRODUCT
  LOW_STOCK
  SUPPLIER_STATUS
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String    @unique
  passwordHash  String
  fullName      String
  role          Role      @default(CUSTOMER)
  locale        String    @default("en")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses     Address[]
  favorites     Favorite[]
  orders        Order[]
  reviews       Review[]
  notifications Notification[]
  supplier      Supplier?
  deliveries    Delivery[] @relation("DeliveryPerson")
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String   @default("Home")
  fullAddress String
  district    String?
  sector      String?
  gpsLat      Float?
  gpsLng      Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Supplier {
  id                 String             @id @default(cuid())
  userId             String             @unique
  businessName       String
  description        String?
  location           String
  district           String
  phone              String
  documentsUrl       String?
  status             SupplierStatus     @default(PENDING)
  availability       AvailabilityStatus @default(CLOSED)
  openHour           Int                @default(6)
  closeHour          Int                @default(21)
  ratingAvg          Float              @default(0)
  ratingCount        Int                @default(0)
  rejectionReason    String?
  approvedAt         DateTime?
  isVerified         Boolean            @default(false)
  verificationBadge  String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  products Product[]
  reviews  Review[]
  orders   OrderItem[]
  offers   SupplierOffer[]
}

model Category {
  id          String    @id @default(cuid())
  slug        String    @unique
  nameEn      String
  nameFr      String
  nameRw      String
  description String?
  imageUrl    String?
  sortOrder   Int       @default(0)
  products    Product[]
  offers      SupplierOffer[]
}

model Product {
  id            String   @id @default(cuid())
  supplierId    String
  categoryId    String
  nameEn        String
  nameFr        String
  nameRw        String
  descriptionEn String
  descriptionFr String
  descriptionRw String
  price         Int
  unit          UnitType @default(KG)
  stockQty      Int      @default(0)
  lowStockAt    Int      @default(5)
  isOrganic     Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  isBestSeller  Boolean  @default(false)
  isNewArrival  Boolean  @default(false)
  isActive      Boolean  @default(true)
  ratingAvg     Float    @default(0)
  ratingCount   Int      @default(0)
  location      String?
  /// Districts where this product can be delivered / is available
  availableDistricts String[] @default([])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  supplier   Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category   Category         @relation(fields: [categoryId], references: [id])
  images     ProductImage[]
  orderItems OrderItem[]
  reviews    Review[]
  favorites  Favorite[]
  stockLogs  StockHistory[]
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id                   String        @id @default(cuid())
  orderNumber          String        @unique
  userId               String?
  guestName            String?
  guestPhone           String?
  deliveryAddress      String
  deliveryZone         DeliveryZone
  deliveryFee          Int
  gpsLat               Float?
  gpsLng               Float?
  deliveryInstructions String?
  subtotal             Int
  total                Int
  status               OrderStatus   @default(PENDING)
  scheduledFor         DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user      User?          @relation(fields: [userId], references: [id])
  items     OrderItem[]
  payment   Payment?
  delivery  Delivery?
  statusLog OrderStatusLog[]
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  productId  String
  supplierId String
  quantity   Float
  unitPrice  Int
  lineTotal  Int

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model OrderStatusLog {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  method          PaymentMethod
  phoneNumber     String
  amount          Int
  status          PaymentStatus @default(PENDING)
  transactionRef  String?
  externalId      String?       @unique
  payeePhone      String?
  payeeName       String?
  providerMessage String?
  verifiedAt      DateTime?
  refundedAt      DateTime?
  refundReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Delivery {
  id               String      @id @default(cuid())
  orderId          String      @unique
  deliveryPersonId String?
  status           OrderStatus @default(READY_FOR_PICKUP)
  estimatedMinutes Int?
  pickedAt         DateTime?
  deliveredAt      DateTime?
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  order          Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryPerson User? @relation("DeliveryPerson", fields: [deliveryPersonId], references: [id])
}

model Review {
  id            String   @id @default(cuid())
  userId        String
  productId     String?
  supplierId    String?
  rating        Int
  comment       String?
  photoUrl      String?
  isReported    Boolean  @default(false)
  isHidden      Boolean  @default(false)
  reportReason  String?
  createdAt     DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model StockHistory {
  id        String   @id @default(cuid())
  productId String
  change    Int
  reason    String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String              @id @default(cuid())
  userId    String?
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  isRead    Boolean             @default(false)
  createdAt DateTime            @default(now())
  user      User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Promotion {
  id            String    @id @default(cuid())
  code          String?   @unique
  titleEn       String
  titleFr       String
  titleRw       String
  descriptionEn String?
  descriptionFr String?
  descriptionRw String?
  discountPct   Int?
  discountAmt   Int?
  buyX          Int?
  getY          Int?
  freeDelivery  Boolean   @default(false)
  isFlashSale   Boolean   @default(false)
  isActive      Boolean   @default(true)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime  @default(now())
}

model BusinessHours {
  id               String   @id @default(cuid())
  dayOfWeek        Int
  openHour         Int      @default(6)
  closeHour        Int      @default(21)
  isClosed         Boolean  @default(false)
}

model Holiday {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  name        String
  isClosed    Boolean  @default(true)
}

model EmergencyClosure {
  id        String    @id @default(cuid())
  reason    String
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  isActive  Boolean   @default(true)
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String?
  commentEn String
  commentFr String
  commentRw String
  rating    Int      @default(5)
  avatarUrl String?
  isFeatured Boolean @default(true)
  createdAt DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorName  String?
  action     String
  entity     String
  entityId   String?
  details    String?
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model SupportThread {
  id        String   @id @default(cuid())
  guestName String?
  guestPhone String?
  userId    String?
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  SupportMessage[]
}

model SupportMessage {
  id        String   @id @default(cuid())
  threadId  String
  sender    String   // CUSTOMER | AGENT | SYSTEM
  body      String
  createdAt DateTime @default(now())
  thread    SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String?
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model FaqItem {
  id       String @id @default(cuid())
  questionEn String
  questionFr String
  questionRw String
  answerEn   String
  answerFr   String
  answerRw   String
  sortOrder  Int @default(0)
  isPublished Boolean @default(true)
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  PURCHASED
}

/// Supplier offers produce for Youth Huza to buy (procurement), not for direct customer sales.
model SupplierOffer {
  id              String      @id @default(cuid())
  supplierId      String
  categoryId      String?
  title           String
  description     String?
  unit            UnitType    @default(KG)
  quantityOffered Float
  /// Price Youth Huza would pay the supplier (RWF per unit)
  askPrice        Int
  /// Optional suggested retail price for Huza to sell at
  suggestedRetail Int?
  availableDistricts String[]  @default([])
  status          OfferStatus @default(PENDING)
  adminNote       String?
  purchasedQty    Float?
  /// Huza product created when offer is purchased
  productId       String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id])
}

